# Shared secret — set the same value on both server and client
LABEL_TOKEN=change-me-to-something-secret

# Client only: full URL to your relay server (no trailing slash)
RELAY_URL=https://yourserver.com

# Client only: which printer to use by default (must match Windows printer name exactly)
# Leave blank to auto-select the first available printer
DEFAULT_PRINTER=

# Client only: default label size key (must be one of: 2x1, 4x2, 4x6, 3x2, 2x0.5)
DEFAULT_SIZE=2x1

# Client only: how often to poll the relay server (seconds)
POLL_SECS=3
