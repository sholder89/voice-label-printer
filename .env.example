# Shared secret — set the same value on both server and client
LABEL_TOKEN=change-me-to-something-secret

# Client only: full URL to your relay server (no trailing slash)
RELAY_URL=https://yourserver.com

# Client only: which printer to use by default (must match Windows printer name exactly)
# Leave blank to auto-select the first available printer
DEFAULT_PRINTER=

# Client only: default label size key
# (one of: 2x1, 4x2, 4x6, 3x2, 2x0.5, 1.1x3.5, 1.1x2.4)
DEFAULT_SIZE=2x1

# Client only: default font style
# (standard, enhanced, impact, serif, narrow, mono, consolas, bahnschrift, burbank, inkfree)
DEFAULT_FONT_STYLE=enhanced

# Client only: default font weight (normal, bold, italic, bold_italic)
DEFAULT_FONT_WEIGHT=bold

# Client only: how often to poll the relay server (seconds)
POLL_SECS=3

# Client only: Telegram notifications on each print (optional).
# Easier to configure live from the Advanced Settings page, but this seeds the
# initial credentials. Format: telegram://<bot_token>@telegram?chats=<chat_id>
SHOUTRRR_URL=
