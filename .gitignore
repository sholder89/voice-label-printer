# ── Secrets ───────────────────────────────────────────────────────────────────
# NOTE: gitignore has no inline comments — a trailing "#" becomes part of the
# pattern, so every comment must be on its own line above the pattern.
# root-level env vars
.env
# server env — contains LABEL_TOKEN, never commit
server/.env
# client env — also holds LABEL_TOKEN
client/.env

# ── Claude Code local settings ────────────────────────────────────────────────
.claude/settings.local.json

# ── Runtime data (stored in %APPDATA%\LabelPrinter, not here) ─────────────────
client/settings.json
client/history.json
client/addresses.json

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Docker ────────────────────────────────────────────────────────────────────
server/jobs.db
# VPS-specific overrides (real domain, LAN IP)
server/docker-compose.override.yml

# ── Dev utilities (not needed by end users) ───────────────────────────────────
make_favicon.py
