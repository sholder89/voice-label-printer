server/.env          # contains LABEL_TOKEN — never commit this

# ── Claude Code local settings ────────────────────────────────────────────────
.claude/settings.local.json

# ── Runtime data (stored in %APPDATA%\LabelPrinter, not here) ─────────────────
client/settings.json
client/history.json
client/addresses.json

